<h1>Registro de Bootcamp</h1>

<form action="/add-student" method="POST">
    <input type="text" name="name" placeholder="Nombre del estudiante" required>
    <input type="email" name="email" placeholder="Correo electrónico" required>
    <button type="submit">Registrar</button>
</form>

<h2>Estudiantes Inscritos:</h2>
<ul>
    {{#each students}}
        <li style="margin-bottom: 10px;">
            <strong>{{this.name}}</strong>  {{this.email}}
            
            <a href="/edit/{{this.id}}">
                <button type="button">Editar</button>
            </a>

            <form action="/delete/{{this.id}}" method="POST" style="display:inline;">
                <button type="submit" style="color: red;">Eliminar</button>
            </form>
        </li>
    {{else}}
        <li>Aún no hay estudiantes registrados en este cohort.</li>
    {{/each}}
</ul>